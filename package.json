{
  "name": "openclaw-windows",
  "version": "2026.2.20",
  "description": "OpenClaw Windows desktop application",
  "main": "dist-electron/main.js",
  "author": "OpenClaw",
  "private": true,
  "scripts": {
    "build:electron": "tsc -p tsconfig.json",
    "build:gateway": "node scripts/build-gateway.mjs",
    "fetch:node": "node scripts/fetch-node.mjs",
    "stage": "node scripts/stage-resources.mjs",
    "build:full": "node scripts/build-gateway.mjs && node scripts/stage-resources.mjs && node scripts/fetch-node.mjs && npm run build:electron && electron-builder --win",
    "dist": "electron-builder --win",
    "start": "electron ."
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "ai.openclaw.windows",
    "productName": "OpenClaw",
    "copyright": "Copyright © 2026 OpenClaw",
    "icon": "assets/icon.ico",
    "files": [
      "dist-electron/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../openclaw/dist",
        "to": "gateway/dist"
      },
      {
        "from": "../openclaw/extensions",
        "to": "gateway/extensions",
        "filter": [
          "**/*",
          "!**/node_modules/**"
        ]
      },
      {
        "from": "../openclaw/skills",
        "to": "gateway/skills",
        "filter": [
          "**/*",
          "!**/node_modules/**"
        ]
      },
      {
        "from": "../openclaw/docs",
        "to": "gateway/docs"
      },
      {
        "from": "../openclaw/openclaw.mjs",
        "to": "gateway/openclaw.mjs"
      },
      {
        "from": "../openclaw/package.json",
        "to": "gateway/package.json"
      },
      {
        "from": "gateway-deploy/node_modules",
        "to": "gateway/node_modules",
        "filter": [
          "**/*",
          "!**/.cache/**"
        ]
      },
      {
        "from": "node-dist/win-x64",
        "to": "node",
        "filter": [
          "node.exe"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenClaw",
      "include": "nsis/installer.nsi"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "gmittalg",
        "repo": "openclaw-easy-windows-install"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
